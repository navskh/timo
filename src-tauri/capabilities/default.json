{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "default permissions: sidecar execution, updater, process restart, notifications",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "updater:default",
    "process:allow-restart",
    "notification:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/node",
          "sidecar": true,
          "args": [{ "validator": ".*" }]
        }
      ]
    }
  ]
}
