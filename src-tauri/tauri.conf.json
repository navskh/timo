{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TIMO",
  "version": "../package.json",
  "identifier": "dev.navskh.timo",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://localhost:3789",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && node scripts/tauri-prepare.js"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/navskh/timo/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIzMDdENkUwQzE4RDgzQjMKUldTemc0M0I0TllISThSWndWa2RRMUp5dnd1QVFZSnAyemFvT2s4alg5NGxndEVSL204UHEyTmcK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/node"],
    "resources": {
      "server-resources": "server-resources"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-",
      "entitlements": "entitlements.plist"
    }
  }
}
